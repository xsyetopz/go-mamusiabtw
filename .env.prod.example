# Minimal production env
DISCORD_TOKEN=

MAMUSIABTW_PROD_MODE=1
MAMUSIABTW_ALLOW_UNSIGNED_PLUGINS=0

# Optional: storage location override
# SQLITE_PATH=./data/mamusiabtw.sqlite

# Optional: enable admin API (dashboard backend).
# If enabled in prod mode, OAuth + session config MUST be complete.
# MAMUSIABTW_ADMIN_ADDR=0.0.0.0:8081
# MAMUSIABTW_DASHBOARD_APP_ORIGIN=https://app.example.com
# MAMUSIABTW_DASHBOARD_REDIRECT_URL=https://api.example.com/api/auth/callback
# MAMUSIABTW_DASHBOARD_CLIENT_ID=
# MAMUSIABTW_DASHBOARD_CLIENT_SECRET=
# MAMUSIABTW_DASHBOARD_SESSION_SECRET=change-me-change-me-change-me-change-me

# Optional: fallback if Discord owner lookup fails (rare).
# OWNER_USER_ID=123456789012345678

