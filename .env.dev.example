# Minimal dev env (bot only)
DISCORD_TOKEN=

# Optional: speed up command iteration by registering commands to one guild only.
# DISCORD_DEV_GUILD_ID=123456789012345678

# Optional: enable the admin API (dashboard backend). `mamusiabtw dev` defaults this
# to 127.0.0.1:8081 if unset.
# MAMUSIABTW_ADMIN_ADDR=127.0.0.1:8081

# Optional: enable Discord OAuth sign-in for the dashboard.
# Discord Developer Portal -> OAuth2.
# MAMUSIABTW_DASHBOARD_CLIENT_ID=
# MAMUSIABTW_DASHBOARD_CLIENT_SECRET=

# Optional: fallback if Discord owner lookup fails (rare).
# OWNER_USER_ID=123456789012345678

