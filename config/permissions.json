{
  "$schema": "https://raw.githubusercontent.com/xsyetopz/go-mamusiabtw/refs/heads/main/schemas/permissions.schema.v1.json",
  "version": "1",
  "defaults": {
    "storage": {
      "kv": false,
      "user_settings": false,
      "checkins": false,
      "reminders": false,
      "warnings": false,
      "audit": false
