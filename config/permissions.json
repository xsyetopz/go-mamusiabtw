        "set_slowmode": true,
        "set_nickname": true,
        "create_role": true,
        "edit_role": true,
        "delete_role": true,
        "add_role": true,
        "remove_role": true,
        "list_messages": true,
        "delete_message": true,
        "bulk_delete_messages": true,
        "purge_messages": true,
        "create_emoji": true,
        "edit_emoji": true,
        "delete_emoji": true,
        "create_sticker": true,
        "edit_sticker": true,
        "delete_sticker": true
