    "discord": {
      "get_self_user": false,
      "get_user": false,
      "get_member": false,
      "get_guild": false,
      "get_role": false,
      "get_channel": false,
      "send_channel": false,
      "send_dm": false,
      "timeout_member": false,
      "set_slowmode": false,
      "set_nickname": false,
      "create_role": false,
      "edit_role": false,
      "delete_role": false,
      "add_role": false,
      "remove_role": false,
      "list_messages": false,
      "delete_message": false,
      "bulk_delete_messages": false,
      "purge_messages": false,
      "create_emoji": false,
      "edit_emoji": false,
      "delete_emoji": false,
      "create_sticker": false,
      "edit_sticker": false,
