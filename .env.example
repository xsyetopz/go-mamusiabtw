# Discord Developer Portal
DISCORD_TOKEN=

# Optional: Kawaii API token (for /hug /pat /poke /shrug)
KAWAII_TOKEN=anonymous

# SQLite
SQLITE_PATH=./data/mamusiabtw.sqlite
MIGRATIONS_DIR=./migrations/sqlite

# Localisation
LOCALES_DIR=./locales

# Plugins
PLUGINS_DIR=./plugins
MAMUSIABTW_PERMISSIONS_FILE=./config/permissions.json
MAMUSIABTW_PROD_MODE=0
MAMUSIABTW_ALLOW_UNSIGNED_PLUGINS=1
MAMUSIABTW_TRUSTED_KEYS_FILE=./config/trusted_keys.json

# Cooldowns (milliseconds)
MAMUSIABTW_SLASH_COOLDOWN_MS=5000
MAMUSIABTW_COMPONENT_COOLDOWN_MS=750
MAMUSIABTW_MODAL_COOLDOWN_MS=1500
# Comma-separated slash commands that bypass cooldown
MAMUSIABTW_SLASH_COOLDOWN_BYPASS=ping,help,plugins,block,unblock
# Optional: per-command override in milliseconds (comma-separated name=ms pairs)
# Examples:
# - MAMUSIABTW_SLASH_COOLDOWN_OVERRIDES_MS=lookup=8000,warn=15000
# - MAMUSIABTW_SLASH_COOLDOWN_OVERRIDES_MS=lookup:user=2500,lookup:guild=8000
# - MAMUSIABTW_SLASH_COOLDOWN_OVERRIDES_MS=manager:roles:add=2500
MAMUSIABTW_SLASH_COOLDOWN_OVERRIDES_MS=

# Optional: register commands to a single dev guild for fast iteration
# DISCORD_DEV_GUILD_ID=123456789012345678

# Command registration (when DISCORD_DEV_GUILD_ID is not set)
# Modes: global | guilds | hybrid
MAMUSIABTW_COMMAND_REGISTRATION_MODE=global
# Comma-separated guild IDs to also register commands into (used by guilds/hybrid)
MAMUSIABTW_COMMAND_GUILD_IDS=
# If 1, attempt to register commands into every cached guild after startup
MAMUSIABTW_COMMAND_REGISTER_ALL_GUILDS=0

# Owner-only commands
# OWNER_USER_IDS=123456789012345678,234567890123456789
