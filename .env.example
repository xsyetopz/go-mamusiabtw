# Discord Developer Portal
DISCORD_TOKEN=

# Optional: Kawaii API token (for /hug /pat /poke /shrug)
KAWAII_TOKEN=anonymous

# SQLite
SQLITE_PATH=./data/imotherbtw.sqlite
MIGRATIONS_DIR=./migrations/sqlite

# Localisation
LOCALES_DIR=./locales

# Plugins
PLUGINS_DIR=./plugins
JAGPDA_PERMISSIONS_FILE=./config/permissions.json
JAGPDA_PROD_MODE=0
JAGPDA_ALLOW_UNSIGNED_PLUGINS=1
JAGPDA_TRUSTED_KEYS_FILE=./config/trusted_keys.json

# Cooldowns (milliseconds)
JAGPDA_SLASH_COOLDOWN_MS=5000
JAGPDA_COMPONENT_COOLDOWN_MS=750
JAGPDA_MODAL_COOLDOWN_MS=1500
# Comma-separated slash commands that bypass cooldown
JAGPDA_SLASH_COOLDOWN_BYPASS=ping,help,plugins,block,unblock

# Optional: register commands to a single dev guild for fast iteration
# DISCORD_DEV_GUILD_ID=123456789012345678

# Command registration (when DISCORD_DEV_GUILD_ID is not set)
# Modes: global | guilds | hybrid
JAGPDA_COMMAND_REGISTRATION_MODE=global
# Comma-separated guild IDs to also register commands into (used by guilds/hybrid)
JAGPDA_COMMAND_GUILD_IDS=
# If 1, attempt to register commands into every cached guild after startup
JAGPDA_COMMAND_REGISTER_ALL_GUILDS=0

# Owner-only commands
# OWNER_USER_IDS=123456789012345678,234567890123456789
