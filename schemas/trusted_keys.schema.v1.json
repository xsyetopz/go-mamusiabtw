{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xsyetopz/go-mamusiabtw/refs/heads/main/schemas/trusted_keys.schema.v1.json",
  "title": "mamusiabtw trusted signer keys",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "keys": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "key_id": {
            "type": "string",
            "minLength": 1
          },
          "public_key_b64": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "key_id",
          "public_key_b64"
        ]
      }
    }
  },
  "required": [
    "keys"
  ]
}
