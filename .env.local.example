# Discord Developer Portal
DISCORD_TOKEN=

# SQLite
SQLITE_PATH=./data/mamusiabtw.sqlite
MIGRATIONS_DIR=./migrations/sqlite
MAMUSIABTW_MIGRATION_BACKUPS_DIR=./data/migration_backups

# Ops HTTP server (optional)
MAMUSIABTW_OPS_ADDR=

# Website + dashboard API
MAMUSIABTW_ADMIN_ADDR=127.0.0.1:8081
MAMUSIABTW_DASHBOARD_APP_ORIGIN=http://127.0.0.1:5173
MAMUSIABTW_DASHBOARD_CLIENT_ID=
MAMUSIABTW_DASHBOARD_CLIENT_SECRET=
MAMUSIABTW_DASHBOARD_REDIRECT_URL=http://127.0.0.1:8081/api/auth/callback
# At least 32 characters
MAMUSIABTW_DASHBOARD_SESSION_SECRET=
# Optional: configured signer for owner-area "sign plugin" action
MAMUSIABTW_DASHBOARD_SIGNING_KEY_ID=
MAMUSIABTW_DASHBOARD_SIGNING_KEY_FILE=

# Localisation
LOCALES_DIR=./locales

# Plugins
PLUGINS_DIR=./plugins
MAMUSIABTW_PERMISSIONS_FILE=./config/permissions.json
MAMUSIABTW_MODULES_FILE=./config/modules.json
MAMUSIABTW_PROD_MODE=0
MAMUSIABTW_ALLOW_UNSIGNED_PLUGINS=1
MAMUSIABTW_TRUSTED_KEYS_FILE=./config/trusted_keys.json

# Cooldowns (milliseconds)
MAMUSIABTW_SLASH_COOLDOWN_MS=5000
MAMUSIABTW_COMPONENT_COOLDOWN_MS=750
MAMUSIABTW_MODAL_COOLDOWN_MS=1500
MAMUSIABTW_SLASH_COOLDOWN_BYPASS=ping,help,plugins,modules,block,unblock
MAMUSIABTW_SLASH_COOLDOWN_OVERRIDES_MS=

# Optional: register commands to a single dev guild for fast iteration
# DISCORD_DEV_GUILD_ID=123456789012345678

# Command registration (when DISCORD_DEV_GUILD_ID is not set)
# Modes: global | guilds | hybrid
MAMUSIABTW_COMMAND_REGISTRATION_MODE=global
MAMUSIABTW_COMMAND_GUILD_IDS=
MAMUSIABTW_COMMAND_REGISTER_ALL_GUILDS=0

# Optional: local fallback if Discord application owner lookup is unavailable
# OWNER_USER_ID=123456789012345678
